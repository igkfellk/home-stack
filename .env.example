# ============================================
# HOME-STACK Переменные окружения
# ============================================
# Скопируйте этот файл в .env и заполните своими значениями
# Никогда не коммитьте .env в репозиторий!
# ============================================

# --- MTG (Telegram MTProto Proxy) ---
# Получить: https://core.telegram.org/getting-started#creating-a-secret
MTG_HEX_SECRET=your_mtg_hex_secret_here

# --- MongoDB ---
# Сгенерировать: openssl rand -base64 32
MTG_MONGO_ROOT_PASS=your_mongo_secure_password_here

# --- 3X-UI ---
# Получить в панели 3X-UI: Настройки → API
XUI_API_TOKEN=your_xui_api_token_here

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASS=your_grafana_secure_password_here

# --- Telegram Reports ---
# Создать бота: @BotFather в Telegram
TG_BOT_TOKEN=your_telegram_bot_token_here
# ID чата: @userinfobot или @getmyid_bot
TG_CHAT_ID=your_telegram_chat_id_here
# ID топика (опционально, если используете форумы)
# Для ежедневных отчетов по клиентам
TG_THREAD_ID=your_telegram_thread_id_here
# Для уведомлений о бэкапах
TG_THREAD_ID_BACKUP=97

# Telegram Bot Token (для backup.sh и AlertManager)
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
TG_THREAD_ID=your_telegram_thread_id_here
TG_THREAD_ID_ALERTS=your_telegram_thread_id_for_alerts_here

# XUI Domain (для монтирования сертификатов)
XUI_DOMAIN=your-domain.com
